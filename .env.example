# Cross-repo links into the Metric ecosystem (env-driven, never hardcoded).
# Vite only exposes vars prefixed with VITE_.
VITE_SITE_URL=http://localhost:5174   # metric-site (marketing)
VITE_APP_URL=http://localhost:5173    # AdMetrics dashboard

# Backend. Postgres 16 for Prisma. Locally this reuses the shared
# `metrics_postgres` container (from the metric-App repo's docker-compose),
# in a separate `metric_planner` database. Create it once with:
#   docker exec metrics_postgres psql -U metrics -d metrics -c "CREATE DATABASE metric_planner;"
#   corepack pnpm exec prisma migrate dev
DATABASE_URL="postgresql://metrics:metrics_dev@localhost:5432/metric_planner?schema=public"

# Express API port (server/index.js). Vite proxies /api here in dev.
# Deliberately NOT named PORT — that one is reserved for the Vite dev server.
API_PORT=4001
